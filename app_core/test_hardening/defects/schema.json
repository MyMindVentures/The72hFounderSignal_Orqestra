{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "module", "severity", "status", "title"],
  "properties": {
    "id": { "type": "string" },
    "module": { "type": "string" },
    "severity": { "enum": ["P0", "P1", "P2", "P3"] },
    "status": {
      "enum": ["open", "in_progress", "fixed", "verified", "closed"]
    },
    "title": { "type": "string" },
    "detectedInPhase": { "type": "string" },
    "repro": { "type": "string" },
    "rootCause": { "type": "string" },
    "fixCommit": { "type": "string" },
    "verifiedInPhase": { "type": "string" },
    "closedAt": { "type": "string" },
    "testCaseIds": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
